@model IEnumerable<TMS.Models.Notification>

@{
    ViewData["Title"] = "Notifications";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Notifications</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle-fill"></i> Create New
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover table-bordered responsive-card-table align-middle">
        <thead class="thead-dark">
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.UserId)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Message)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.NotificationDate)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.status)
                </th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td data-label="@Html.DisplayNameFor(model => model.UserId)">
                        @Html.DisplayFor(modelItem => item.UserId)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.Message)">
                        @Html.DisplayFor(modelItem => item.Message)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.NotificationDate)">
                        @Html.DisplayFor(modelItem => item.NotificationDate)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.status)">
                        @Html.DisplayFor(modelItem => item.status)
                    </td>
                    <td data-label="Actions" class="text-nowrap">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-info me-1" title="Edit">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-secondary me-1" title="Details">
                            <i class="bi bi-card-list"></i> Details
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
