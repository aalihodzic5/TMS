@{
    ViewData["Title"] = "Jobs in map view";
}


<div class="row mt-4">
    <div class="col-md-8">
        <div id="map" style="height: 600px; width: 100%;"></div>
    </div>
    <div class="col-md-4">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h5 class="mb-0">Results</h5>
            <a href="/Job/Filter" class="btn btn-outline-secondary btn-sm" title="Back to filter">
                <i class="bi bi-funnel-fill"></i> Back to Filter
            </a>
        </div>

        <div style="max-height: 600px; overflow-y: auto;" class="border rounded">
            <table id="localResultsTable" class="table table-sm table-bordered table-striped responsive-card-table align-middle">
                <thead class="thead-dark">
                    <tr>
                        <th>Date</th>
                        <th>Origin</th>
                        <th>Dest</th>
                        <th>Price</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- JavaScript će ubaciti redove ovdje -->
                </tbody>
            </table>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.3/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.3/dist/leaflet.js"></script>

<link href="https://api.mapbox.com/mapbox-gl-js/v3.13.0/mapbox-gl.css" rel="stylesheet">
<script src="https://api.mapbox.com/mapbox-gl-js/v3.13.0/mapbox-gl.js"></script>
<script src="https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-directions/v4.3.1/mapbox-gl-directions.js"></script>
<link rel="stylesheet" href="https://api.mapbox.com/mapbox-gl-js/plugins/mapbox-gl-directions/v4.3.1/mapbox-gl-directions.css" type="text/css">

<script>
const map = L.map('map').setView([43.8563, 18.4131], 7);
const baseLayers = {
    "🗺️ Streets (Default)": L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
    }),

    "🌍 Satellite": L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
        attribution: '&copy; Esri &mdash; Source: Esri, i-cubed, USDA, USGS, AEX, GeoEye, Getmapping, Aerogrid, IGN, IGP, UPR-EGP, and the GIS User Community'
    }),

    "⛰️ Terrain": L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', {
        attribution: 'Map data: &copy; OpenTopoMap contributors'
    }),

    "🚗 Traffic (via OpenStreetMap France)": L.tileLayer('https://{s}.tile.openstreetmap.fr/hot/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap France'
    })
};

baseLayers["🗺️ Streets (Default)"].addTo(map);


    L.control.layers(
        {
            "🗺️ Streets": baseLayers["🗺️ Streets (Default)"],
            "🌍 Satellite": baseLayers["🌍 Satellite"],
            "⛰️ Terrain": baseLayers["⛰️ Terrain"],
            "🚗 Traffic": baseLayers["🚗 Traffic (via OpenStreetMap France)"]
        },
        null,
        { position: 'topright', collapsed: false }
    ).addTo(map);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);
    
    let routeLine = null;
    let markers = [];
    let clickedPoints = [];

    async function geocodeLocation(location) {
        const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(location)}`;
        const response = await fetch(url);
        const data = await response.json();
        if (data.length > 0) {
            return {
                lat: parseFloat(data[0].lat),
                lng: parseFloat(data[0].lon)
            };
        } else {
            throw new Error(`Lokacija nije pronađena: ${location}`);
        }
    }

    async function reverseGeocode(lat, lng) {
        const url = `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`;
        const response = await fetch(url);
        const data = await response.json();
        return data.display_name || "Nepoznata lokacija";
    }

    async function getRoute(start, end) {

        const response = await fetch('/Job/GetRoute', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify([start, end])
        });

        if (!response.ok) {
            const errorMessage = await response.text();
            throw new Error("Greška prilikom dohvata rute:\n" + errorMessage);
        }

        const data = await response.json();

        if (!data) {
            alert("Ruta nije pronađena.");
            return;
        }

        
        const coords = data.routes[0].geometry.coordinates;
        addRouteToMap(coords);
        
    }

            function addRouteToMap(coordinates) {
        const latlngs = coordinates.map(c => [c[1], c[0]]); 

        if (routeLine) {
            map.removeLayer(routeLine);
        }

        routeLine = L.polyline(latlngs, {
            color: 'blue',
            weight: 5,
            opacity: 0.8
        }).addTo(map);

        map.fitBounds(routeLine.getBounds());
    }

    map.on('click', async function (e) {
        const { lat, lng } = e.latlng;

        if (clickedPoints.length >= 2) {
            clickedPoints = [];
            markers.forEach(m => map.removeLayer(m));
            markers = [];
            if (routeLine) map.removeLayer(routeLine);
        }

        clickedPoints.push([lng, lat]);

        const label = clickedPoints.length === 1 ? "Start" : "End";
        const iconUrl = clickedPoints.length === 1
            ? 'https://maps.google.com/mapfiles/ms/icons/green-dot.png'
            : 'https://maps.google.com/mapfiles/ms/icons/red-dot.png';

        const marker = L.marker([lat, lng], {
            icon: L.icon({
                iconUrl: iconUrl,
                iconSize: [32, 32],
                iconAnchor: [16, 32]
            })
        }).addTo(map);

        const address = await reverseGeocode(lat, lng);
        marker.bindPopup(`${label}:<br>${address}`).openPopup();
        markers.push(marker);

        if (clickedPoints.length === 2) {
            await getRoute(clickedPoints[0], clickedPoints[1]);
        }
    });

    document.getElementById("routeForm").addEventListener("submit", async function (e) {
        e.preventDefault();

        const startLocation = document.getElementById("start").value;
        const endLocation = document.getElementById("end").value;

        try {
            const start = await geocodeLocation(startLocation);
            const end = await geocodeLocation(endLocation);

            if (routeLine) map.removeLayer(routeLine);
            markers.forEach(m => map.removeLayer(m));
            markers = [];
            clickedPoints = [];

            const startMarker = L.marker([start.lat, start.lng]).addTo(map).bindPopup("Start").openPopup();
            const endMarker = L.marker([end.lat, end.lng]).addTo(map).bindPopup("End");
            markers.push(startMarker, endMarker);

            await getRoute([start.lng, start.lat], [end.lng, end.lat]);
        } catch (err) {
            console.error("Greška:", err);
            alert("Došlo je do greške: " + err.message);
        }
    });
</script>

<script>
    const storedResults = JSON.parse(localStorage.getItem("searchResults") || "[]");
    const tableBody = document.querySelector("#localResultsTable tbody");

    if (storedResults.length === 0) {
        tableBody.innerHTML = "<tr><td colspan='4' class='text-center'>Nema spremljenih podataka.</td></tr>"; // colspan changed to 4 as there are 4 columns
    } else {
        storedResults.forEach(job => {
            const row = document.createElement("tr");

            const rawId = job.id ?? job.jobId ?? job.Id ?? job.ID ?? null;
            const jobId = rawId != null ? Number(rawId) : null;
            const hasValidId = Number.isInteger(jobId) && jobId > 0;

            const cijena =
                typeof job.price === "number"
                    ? job.price.toFixed(2)
                    : (parseFloat(job.price) ? parseFloat(job.price).toFixed(2) : "0.00");

            row.innerHTML = `
                <td>${new Date(job.postingDate).toLocaleDateString()}</td>
                <td>${job.locationOrigin || "-"}</td>
                <td>${job.locationDestination || "-"}</td>
                <td>${cijena} €</td>
            `;

            let clickTimer = null; 

            row.addEventListener("click", async () => {
                clickTimer = setTimeout(async () => {
                    try {
                        const start = await geocodeLocation(job.locationOrigin);
                        const end = await geocodeLocation(job.locationDestination);

                        markers.forEach(m => map.removeLayer(m));
                        markers = [];
                        if (routeLine) map.removeLayer(routeLine);

                        const markerStart = L.marker([start.lat, start.lng]).addTo(map).bindPopup("Start").openPopup();
                        const markerEnd = L.marker([end.lat, end.lng]).addTo(map).bindPopup("End").openPopup();
                        markers.push(markerStart, markerEnd);

                        await getRoute([start.lng, start.lat], [end.lng, end.lat]);
                    } catch (error) {
                        alert("Ne mogu prikazati rutu: " + error.message);
                    }
                }, 800);
            });

            row.addEventListener("dblclick", () => {
                clearTimeout(clickTimer); 
                if (hasValidId) {
                    window.location.href = `/Job/Details/${jobId}`;
                } else {
                    console.warn("Job nema validan ID za Details link na dvostruki klik:", job);
                    alert("Detalji za ovaj posao nisu dostupni (nedostaje ID).");
                }
            });

            if (!hasValidId) {
                console.warn("Job nema validan ID:", job);
            }

            tableBody.appendChild(row);
        });
    }
</script>

