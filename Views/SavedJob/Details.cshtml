@model TMS.Models.SavedJob

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>


<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header d-flex align-items-center" style="background-color: #2c2f33; color: #ffffff;">
            <h3 class="mb-0 me-auto">
                <i class="fa-solid fa-floppy-disk fa-2x me-2"></i> Saved Job Details
            </h3>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-light btn-sm">
                <i class="fa-solid fa-pen-to-square me-1"></i> Edit
            </a>
        </div>

        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <h6 class="text-muted">User</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-user me-1"></i>@Model.User?.UserName
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Job ID</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-briefcase me-1"></i>@Model.JobId
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Saved Date</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-bookmark me-1"></i>@Model.savedDate
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Load Date</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-calendar-day me-1"></i>@Model.Job.loadDate
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Trailer Type</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-trailer me-1"></i>@Model.Job.TrailerTypes
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Load Type</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-box me-1"></i>@Model.Job.LoadType
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Distance Origin</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-road me-1"></i>@Model.Job.distanceOrigin km
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Distance Destination</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-route me-1"></i>@Model.Job.distanceDestination km
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Location Origin</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-map-marker-alt me-1"></i>@Model.Job.locationOrigin
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Location Destination</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-flag-checkered me-1"></i>@Model.Job.locationDestination
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Company Name</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-building me-1"></i>@Model.Job.companyName
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Load Weight</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-weight-hanging me-1"></i>@Model.Job.loadWeight
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Load Length</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-ruler-horizontal me-1"></i>@Model.Job.loadLength
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Price</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-euro-sign me-1"></i>@Model.Job.price
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Comments</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-comment-dots me-1"></i>@Model.Job.comments
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Posting Date</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-calendar-days me-1"></i>@Model.Job.postingDate
                    </p>
                </div>
            </div>
        </div>

        <div class="card-footer text-end bg-light rounded-bottom-4">
            <a class="btn btn-outline-secondary" href="@Context.Request.Query["returnUrl"].ToString()">
                <i class="fa-solid fa-arrow-left me-1"></i> Back to List
            </a>
        </div>
    </div>
</div>
