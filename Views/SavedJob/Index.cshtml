@model IEnumerable<TMS.Models.SavedJob>
@{
    ViewData["Title"] = "My Saved Jobs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">My Saved Jobs</h2>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle"></i> No saved jobs yet.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover table-bordered responsive-card-table align-middle">
            <thead class="thead-dark">
                <tr>
                    <th>Job ID</th>
                    <th>Saved at</th>
                    <th>Origin</th>
                    <th>Destination</th>
                    <th>Load date</th>
                    <th>Trailer</th>
                    <th>Load type</th>
                    <th>Price</th>
                    <th class="text-center">Compare</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr data-jobid="@item.JobId">
                        <td data-label="Job ID">@item.Job?.Id</td>
                        <td data-label="Saved at">@item.savedDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td data-label="Origin">@item.Job?.locationOrigin</td>
                        <td data-label="Destination">@item.Job?.locationDestination</td>
                        <td data-label="Load date">@item.Job?.loadDate.ToShortDateString()</td>
                        <td data-label="Trailer">@item.Job?.TrailerTypes</td>
                        <td data-label="Load type">@item.Job?.LoadType</td>
                        <td data-label="Price" class="text-end">@item.Job?.price.ToString("C")</td>

                        <td data-label="Compare" class="text-center">
                            <button type="button"
                                    class="btn btn-sm btn-outline-primary btn-compare"
                                    onclick="addToCompare(@item.JobId)"
                                    title="Add to Comparator">
                                <i class="bi bi-bar-chart"></i> Compare
                            </button>
                        </td>

                        <td data-label="Actions" class="text-end text-nowrap">
                            <form method="post" asp-controller="SavedJob" asp-action="Unsave" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="jobId" value="@item.JobId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Remove from saved">
                                    <i class="bi bi-trash"></i> Remove
                                </button>
                            </form>
                            <a asp-controller="SavedJob"
                               asp-action="Details"
                               asp-route-id="@item.Id"
                               asp-route-returnUrl="@Url.Action("Index", "SavedJob")"
                               class="btn btn-sm btn-outline-secondary ms-1" title="View details">
                                <i class="bi bi-card-list"></i> View
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <script>
        (function () {
          const KEY = "compareSelection";

          function getSel() {
            try { return JSON.parse(localStorage.getItem(KEY)) ?? []; }
            catch { return []; }
          }
          function setSel(arr) { localStorage.setItem(KEY, JSON.stringify(arr)); }

          window.addToCompare = function (jobId) {
            let sel = getSel();

            // toggle
            if (sel.includes(jobId)) {
              sel = sel.filter(x => x !== jobId);
            } else {
              sel.push(jobId);
              if (sel.length > 2) sel = sel.slice(sel.length - 2); // zadrži zadnja 2
            }

            setSel(sel);
            updateCompareButtons();

            if (sel.length === 2) {
              const qs = encodeURIComponent(sel.join(","));
              // idi na komparator (controller treba da prima ?ids=12,34)
              window.location.href = `/Comparator?ids=${qs}`;
            }
          };

          function updateCompareButtons() {
            const sel = new Set(getSel());
            document.querySelectorAll("tr[data-jobid]").forEach(row => {
              const id = parseInt(row.getAttribute("data-jobid"));
              const btn = row.querySelector(".btn-compare");
              if (!btn) return;

              if (sel.has(id)) {
                btn.classList.remove("btn-outline-primary");
                btn.classList.add("btn-primary");
                btn.innerHTML = `<i class="bi bi-bar-chart"></i> In compare`;
              } else {
                btn.classList.add("btn-outline-primary");
                btn.classList.remove("btn-primary");
                btn.innerHTML = `<i class="bi bi-bar-chart"></i> Compare`;
              }
            });
          }

          document.addEventListener("DOMContentLoaded", updateCompareButtons);
        })();
    </script>
}
