@model IEnumerable<TMS.Models.SavedJob>
@{
    ViewData["Title"] = "My Saved Jobs";
}

<h2 class="mb-3">My Saved Jobs</h2>

@if (!Model.Any())
{
    <div class="alert alert-info">Još nema sačuvanih poslova.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Saved at</th>
                <th>Origin</th>
                <th>Destination</th>
                <th>Load date</th>
                <th>Trailer</th>
                <th>Load type</th>
                <th>Price</th>
                <th>Compare</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                
                <tr data-jobid="@item.JobId">
                    <td>@item.savedDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@item.Job?.locationOrigin</td>
                    <td>@item.Job?.locationDestination</td>
                    <td>@item.Job?.loadDate.ToShortDateString()</td>
                    <td>@item.Job?.TrailerTypes</td>
                    <td>@item.Job?.LoadType</td>
                    <td class="text-end">@item.Job?.price.ToString("C")</td>

                    <td class="text-center">
                        <button type="button"
                                class="btn btn-sm btn-outline-primary btn-compare"
                                onclick="addToCompare(@item.JobId)"
                                title="Add to Comparator">
                            Compare
                        </button>
                    </td>

                    <td class="text-end">
                        <form method="post" asp-controller="SavedJob" asp-action="Unsave" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="jobId" value="@item.JobId" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                        </form>
                        <a asp-controller="Job" asp-action="Details" asp-route-id="@item.JobId" class="btn btn-sm btn-outline-secondary ms-1">
                            View
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script>
        (function () {
          const KEY = "compareSelection";

          function getSel() {
            try { return JSON.parse(localStorage.getItem(KEY)) ?? []; }
            catch { return []; }
          }
          function setSel(arr) { localStorage.setItem(KEY, JSON.stringify(arr)); }

          window.addToCompare = function (jobId) {
            let sel = getSel();

            // toggle
            if (sel.includes(jobId)) {
              sel = sel.filter(x => x !== jobId);
            } else {
              sel.push(jobId);
              if (sel.length > 2) sel = sel.slice(sel.length - 2); // zadrži zadnja 2
            }

            setSel(sel);
            updateCompareButtons();

            if (sel.length === 2) {
              const qs = encodeURIComponent(sel.join(","));
              // idi na komparator (controller treba da prima ?ids=12,34)
              window.location.href = `/Comparator?ids=${qs}`;
            }
          };

          function updateCompareButtons() {
            const sel = new Set(getSel());
            document.querySelectorAll("tr[data-jobid]").forEach(row => {
              const id = parseInt(row.getAttribute("data-jobid"));
              const btn = row.querySelector(".btn-compare");
              if (!btn) return;
              if (sel.has(id)) {
                btn.classList.remove("btn-outline-primary");
                btn.classList.add("btn-primary");
                btn.textContent = "In compare";
              } else {
                btn.classList.add("btn-outline-primary");
                btn.classList.remove("btn-primary");
                btn.textContent = "Compare";
              }
            });
          }

          document.addEventListener("DOMContentLoaded", updateCompareButtons);
        })();
    </script>
}

