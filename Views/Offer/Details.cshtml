@model TMS.Models.Offer
@using TMS.Models.Enums

@{
    ViewData["Title"] = "Details";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header d-flex align-items-center" style="background-color: #2c2f33; color: #ffffff;">
            <h3 class="mb-0 me-auto">
                <i class="fa-solid fa-handshake fa-2x me-2"></i> Offer Details
            </h3>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-light btn-sm">
                <i class="fa-solid fa-pen-to-square me-1"></i> Edit
            </a>
        </div>

        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <h6 class="text-muted">Report</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-file-lines me-1"></i>@Model.report
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Offer Date</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-calendar-day me-1"></i>@Model.offerDate
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Offered Price</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-hand-holding-dollar me-1"></i>@Model.price
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Original Price</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-tag me-1"></i>@Model.Job.price
                    </p>
                </div>
            </div>
        </div>

        <div class="p-3">
            @if (Model.offerState == OfferState.PENDING)
            {
                <div class="d-flex gap-2">
                    <form asp-controller="Offer" asp-action="Accept" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-success">
                            <i class="fa-solid fa-check me-1"></i> Accept
                        </button>
                    </form>

                    <form asp-controller="Offer" asp-action="Reject" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-danger">
                            <i class="fa-solid fa-xmark me-1"></i> Reject
                        </button>
                    </form>
                </div>
            }
            else if (Model.offerState == OfferState.ACCEPTED)
            {
                <span class="badge bg-success">
                    <i class="fa-solid fa-check me-1"></i> REJECT
                </span>
            }
            else if (Model.offerState == OfferState.REJECTED)
            {
                <span class="badge bg-danger">
                    <i class="fa-solid fa-xmark me-1"></i> ACCEPT
                </span>
            }
        </div>


        <div class="card-footer text-end bg-light rounded-bottom-4">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="fa-solid fa-arrow-left me-1"></i> Back to List
            </a>
        </div>
    </div>
</div>
