@model IEnumerable<TMS.Models.Offer>

@{
    ViewData["Title"] = "Offers";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Offers</h1>
</div>

<div class="table-responsive">
    <table id ="offerTable" class="table table-striped table-hover table-bordered responsive-card-table align-middle">
        <thead class="thead-dark">
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.JobId)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.report)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.offerDate)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.price)
                </th>
                <th>
                    Job Price
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.offerState)
                </th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr data-offer-id = "@item.Id">
                    <td data-label="@Html.DisplayNameFor(model => model.JobId)">
                        @Html.DisplayFor(modelItem => item.JobId)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.report)">
                        @Html.DisplayFor(modelItem => item.report)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.offerDate)">
                        @Html.DisplayFor(modelItem => item.offerDate)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.price)">
                        @Html.DisplayFor(modelItem => item.price)
                    </td>
                    <td data-label="Job Price">
                        @item.Job.price.ToString("C")
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.offerState)">
                        @Html.DisplayFor(modelItem => item.offerState)
                    </td>
                    <td data-label="Actions" class="text-nowrap">
                        @if (User.IsInRole("Administrator") || User.IsInRole("Broker"))
                        {
                            <form asp-controller="Offer"
                                  asp-action="Accept"
                                  asp-route-id="@item.Id"
                                  method="post"
                                  class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success me-1" title="Accept offer">
                                    <i class="bi bi-check-circle"></i> Accept
                                </button>
                            </form>

                            <form asp-controller="Offer"
                                  asp-action="Reject"
                                  asp-route-id="@item.Id"
                                  method="post"
                                  class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger me-1" title="Reject offer">
                                    <i class="bi bi-x-circle"></i> Reject
                                </button>
                            </form>
                        }

                        @if (User.IsInRole("Administrator") || User.IsInRole("Dispatcher"))
                        {
                            <a asp-controller="Offer" asp-action="Assign" asp-route-id="@item.Id" class="btn btn-sm btn-primary me-1" title="Assign offer">
                                <i class="bi bi-person-plus"></i> Assign
                            </a>
                        }
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete offer">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const table = document.getElementById('offerTable');
            if (table) {
                const rows = table.querySelectorAll('tbody tr');
                rows.forEach(row => {
                    row.addEventListener('dblclick', function () {
                        const offerId = this.getAttribute('data-offer-id');
                        if (offerId) {
                            window.location.href = `/Offer/Details/${offerId}`;
                        }
                    });
                });
            }
        });
    </script>
}