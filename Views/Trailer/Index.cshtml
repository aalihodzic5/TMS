@model IEnumerable<TMS.Models.Trailer>

@{
    ViewData["Title"] = "Trailers";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <i class="fa-solid fa-trailer fa-3x me-2"></i>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle-fill"></i> Create New
    </a>
</div>

<div class="table-responsive">
    <table id="trailersTable" class="table table-striped table-hover table-bordered responsive-card-table">
        <thead class="thead-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.brand)</th>
                <th>@Html.DisplayNameFor(model => model.trailerType)</th>
                <th>@Html.DisplayNameFor(model => model.licensePlate)</th>
                <th>@Html.DisplayNameFor(model => model.registration)</th>
                <th>@Html.DisplayNameFor(model => model.nextServiceDate)</th>
                <th>@Html.DisplayNameFor(model => model.specification)</th>
                <th>@Html.DisplayNameFor(model => model.TruckId)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr data-trailer-id="@item.Id" style="cursor: pointer;">
                    <td data-label="@Html.DisplayNameFor(model => model.brand)">
                        @Html.DisplayFor(modelItem => item.brand)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.trailerType)">
                        @Html.DisplayFor(modelItem => item.trailerType)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.licensePlate)">
                        @Html.DisplayFor(modelItem => item.licensePlate)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.registration)">
                        @Html.DisplayFor(modelItem => item.registration)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.nextServiceDate)">
                        @Html.DisplayFor(modelItem => item.nextServiceDate)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.specification)">
                        @Html.DisplayFor(modelItem => item.specification)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.TruckId)">
                        @Html.DisplayFor(modelItem => item.TruckId)
                    </td>
                    <td data-label="Actions" class="text-nowrap">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const table = document.getElementById('trailersTable'); // Promijenjeno iz 'trailerTable' u 'trailersTable'
            const rows = table.querySelectorAll('tbody tr');

            rows.forEach(row => {
                row.addEventListener('dblclick', function () {
                    const trailerId = this.getAttribute('data-trailer-id');
                    if (trailerId) {
                        window.location.href = `/Trailer/Details/${trailerId}`;
                    }
                });
            });
        });
    </script>
}
