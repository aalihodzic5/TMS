@model IEnumerable<TMS.Models.Truck>

@{
    ViewData["Title"] = "Trucks";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Trucks</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle-fill"></i> Create New
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover table-bordered responsive-card-table">
        <thead class="thead-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.brand)</th>
                <th>@Html.DisplayNameFor(model => model.model)</th>
                <th>@Html.DisplayNameFor(model => model.licensePlate)</th>
                <th>@Html.DisplayNameFor(model => model.specification)</th>
                <th>@Html.DisplayNameFor(model => model.nextServiceDate)</th>
                <th>@Html.DisplayNameFor(model => model.registration)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td data-label="@Html.DisplayNameFor(model => model.brand)">
                        @Html.DisplayFor(modelItem => item.brand)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.model)">
                        @Html.DisplayFor(modelItem => item.model)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.licensePlate)">
                        @Html.DisplayFor(modelItem => item.licensePlate)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.specification)">
                        @Html.DisplayFor(modelItem => item.specification)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.nextServiceDate)">
                        @Html.DisplayFor(modelItem => item.nextServiceDate)
                    </td>
                    <td data-label="@Html.DisplayNameFor(model => model.registration)">
                        @Html.DisplayFor(modelItem => item.registration)
                    </td>
                    <td data-label="Actions" class="text-nowrap">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">
                            <i class="bi bi-card-list"></i> Details
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>




