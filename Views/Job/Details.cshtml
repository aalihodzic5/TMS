@model TMS.Models.Job

@{
    ViewData["Title"] = "Details";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header d-flex align-items-center" style="background-color: #2c2f33; color: #ffffff;">
            <h3 class="mb-0 me-auto">
                <i class="fa-solid fa-clipboard-list me-2"></i> Job Details
            </h3>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-light btn-sm">
                <i class="bi bi-pencil-square me-1"></i> Edit
            </a>
        </div>

        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <h6 class="text-muted">Load Date</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-calendar-day me-1"></i>@Model.loadDate
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Trailer Type</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-trailer me-1"></i>@Model.TrailerTypes
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Load Type</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-box me-1"></i>@Model.LoadType
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Distance To Origin</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-road me-1"></i>@Model.distanceOrigin
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Distance To Destination</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-location-dot me-1"></i>@Model.distanceDestination
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Origin Location</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-map-marker-alt me-1"></i>@Model.locationOrigin
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Destination Location</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-flag-checkered me-1"></i>@Model.locationDestination
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Company Name</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-building me-1"></i>@Model.companyName
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Load Weight</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-weight-hanging me-1"></i>@Model.loadWeight
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Load Length</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-ruler-horizontal me-1"></i>@Model.loadLength
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Price</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-euro-sign me-1"></i>@Model.price
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Comments</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-comment-dots me-1"></i>@Model.comments
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Posting Date</h6>
                    <p class="fw-semibold">
                        <i class="fa-solid fa-calendar-days me-1"></i>@Model.postingDate
                    </p>
                </div>
            </div>
        </div>

        <div class="card-footer text-end bg-light rounded-bottom-4">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to List
            </a>
        </div>
    </div>
</div>

