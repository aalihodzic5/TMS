@model List<TMS.Models.Job>
@{
    ViewData["Title"] = "Filter";
    var savedIds = (ViewBag.SavedIds as HashSet<int>) ?? new HashSet<int>();
}

@using System.Text.Json

<form method="get" class="mb-4">

    <div class="row">
        <div class="col-md-3">
            <label>Driver</label>
            <select name="DriverId" class="form-control">
                <option value="">-- Select driver --</option>
                @foreach (var driver in (List<SelectListItem>)ViewBag.DriverList)
                {
                    <option value="@driver.Value">@driver.Text</option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <label>Min price</label>
            <input type="number" name="minPrice" class="form-control" />
        </div>

        <div class="col-md-3">
            <label>Date From</label>
            <input type="date" name="dateFrom" class="form-control" />
        </div>

        <div class="col-md-3">
            <label>Min distance (Load)</label>
            <input type="number" name="minDistanceLoad" class="form-control" />
        </div>
    </div>

    <div class="row mt-2">
        <div class="col-md-3">
            <label>Load type</label>
            <select name="loadType" class="form-control">
                <option value="">-- Select load type --</option>
                @foreach (var loadType in (SelectList)ViewBag.LoadTypes)
                {
                    <option value="@loadType.Value">@loadType.Text</option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <label>Max price</label>
            <input type="number" name="maxPrice" class="form-control" />
        </div>

        <div class="col-md-3">
            <label>Date To</label>
            <input type="date" name="dateTo" class="form-control" />
        </div>

        <div class="col-md-3">
            <label>Max distance (Load)</label>
            <input type="number" name="maxDistanceLoad" class="form-control" />
        </div>
    </div>

    <div class="row mt-2">
        <div class="col-md-3">
            <label>Trailer type</label>
            <select name="trailerType" class="form-control">
                <option value="">-- Select trailer type --</option>
                @foreach (var trailerType in (SelectList)ViewBag.TrailerTypes)
                {
                    <option value="@trailerType.Value">@trailerType.Text</option>
                }
            </select>
        </div>

        
        <div class="col-md-3">
            <label>Company</label>
            <input type="text" name="companyName" class="form-control" />
        </div>

        <div class="col-md-3">
            <label>Destination (Load)</label>
            <input type="text" name="destinationLoad" class="form-control" />
        </div>

        <div class="col-md-3">
            <label>Min Distance (Unload)</label>
            <input type="number" name="minDistanceUnload" class="form-control" />
        </div>
    </div>

    <div class="row mt-2">
        <div class="col-md-3">
            <label>Weight(+-5%)</label>
            <input type="text" name="weight" class="form-control" />
        </div>

        <div class="col-md-3">
            <label>Length(+-5%)</label>
            <input type="text" name="length" class="form-control" />
        </div>

        <div class="col-md-3">
            <label>Destination (Unload)</label>
            <input type="text" name="destinationUnload" class="form-control" />
        </div>

        <div class="col-md-3">
            <label>Max Distance (Unload)</label>
            <input type="number" name="maxDistanceUnload" class="form-control" />
        </div>
    </div>

    

    <div class="row mt-3">
        <div class="col-md-12">
            <button type="submit" class="btn btn-primary w-100">Primijeni filter</button>
        </div>
    </div>
    
</form>

<form asp-controller="Job" asp-action="Map" method="get">
    <div class="row mt-3">
        <div class="col-md-12">
            <button type="submit" class="btn btn-primary w-100">View on map</button>
        </div>
    </div>
</form>


<hr />

<!-- Rezultati -->
<table class="table table-bordered table-striped">
    <thead class="thead-dark">
        <tr>
            <th>Published</th>
            <th>Origin</th>
            <th>Destination</th>
            <th>Date</th>
            <th>Trailer Type</th>
            <th>Load Type</th>
            <th>Distance</th>
            <th>Price</th>
            <th>Save</th>
            <th>Offer</th>
            <th>Assign</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var job in Model)
        {
            <tr>
                <td>@job.postingDate</td>
                <td>@job.locationOrigin</td>
                <td>@job.locationDestination</td>
                <td>@job.loadDate.ToShortDateString()</td>
                <td>@job.TrailerTypes</td>
                <td>@job.LoadType</td>
                <td>@(job.distanceOrigin + job.distanceDestination) km</td>
                <td>@job.price.ToString("C")</td>
                <!-- SAVE / UNSAVE -->
                <td class="text-center">
                    @if (savedIds.Contains(job.Id))
                    {
                        <form method="post" asp-controller="SavedJob" asp-action="Unsave" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="jobId" value="@job.Id" />
                            <button type="submit" class="btn btn-warning btn-sm" title="Remove from saved">★ Saved</button>
                        </form>
                    }
                    else
                    {
                        <form method="post" asp-controller="SavedJob" asp-action="Save" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="jobId" value="@job.Id" />
                            <button type="submit" class="btn btn-outline-warning btn-sm" title="Save this job">☆ Save</button>
                        </form>
                    }
                </td>

                <td>
                    <form method="post" asp-controller="Offer" asp-action="SendOffer" class="d-flex align-items-center">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="jobId" value="@job.Id" />
                        <input type="number" name="offerPrice" class="form-control form-control-sm" step="0.01" placeholder="€" required style="width: 80px;" />
                        <button type="submit" class="btn btn-success btn-sm ms-1">✔</button>
                    </form>
                </td>
                <td>
                    <form method="post" asp-action="AssignDriver" class="d-flex align-items-center">
                        <input type="hidden" name="jobId" value="@job.Id" />
                        <select name="driverId" class="form-select form-select-sm">
                            <option value="">--</option>
                            @foreach (var driver in (List<SelectListItem>)ViewBag.DriverList)
                            {
                                <option value="@driver.Value">@driver.Text</option>
                            }
                        </select>
                        <button type="submit" class="btn btn-sm btn-success ms-1">✔</button>
                    </form>
                </td>

            </tr>
        }
    </tbody>
</table>


@section Scripts {
    <script>
        const searchResults = @Html.Raw(JsonSerializer.Serialize(Model));
        localStorage.setItem("searchResults", JSON.stringify(searchResults));
    </script>
}

