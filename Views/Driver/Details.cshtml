@model TMS.Models.Driver

@{
    ViewData["Title"] = "Driver Details";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header d-flex align-items-center" style="background-color: #2c2f33; color: #ffffff;">
            <h3 class="mb-0 me-auto">
                <i class="bi bi-person-badge me-2"></i> Driver Details
            </h3>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-light btn-sm">
                <i class="bi bi-pencil-square me-1"></i> Edit
            </a>
        </div>




        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <h6 class="text-muted">First Name</h6>
                    <p class="fw-semibold">@Model.FirstName</p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Last Name</h6>
                    <p class="fw-semibold">@Model.LastName</p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Phone Number</h6>
                    <p class="fw-semibold">
                        <i class="bi bi-telephone me-1"></i>@Model.PhoneNumber
                    </p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Date of Birth</h6>
                    <p class="fw-semibold">@Model.DateOfBirth.ToString("dd.MM.yyyy")</p>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Truck ID</h6>
                    <p class="fw-semibold">
                        <i class="bi bi-truck me-1"></i>@Model.TruckId
                    </p>
                </div>
            </div>
        </div>

        <div class="card-footer text-end bg-light rounded-bottom-4">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to List
            </a>
        </div>
    </div>
</div>
